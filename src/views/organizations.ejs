<%- include('partials/header') %>

  <main id="main-content">
    <div class="page-content">
      <div class="container">
        <div class="page-header">
          <h1>
            <%= title %>
          </h1>
          <p>Here are a few of our partner organizations:</p>
        </div>

        <ul class="org-grid" role="list">
          <% organizations.forEach(function(organization) { %>
            <li class="card org-card">
              <img src="/images/<%= organization.logo_filename %>" alt="<%= organization.name %> logo">
              <div class="org-info">
                <h3>
                  <%= organization.name %>
                </h3>
                <a href="mailto:<%= organization.contact_email %>" class="org-email">
                  <%= organization.contact_email %>
                </a>
              </div>
            </li>
            <% }); %>
        </ul>
      </div>
    </div>
  </main>

  <%- include('partials/footer') %>